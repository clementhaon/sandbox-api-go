# Database configuration
DB_HOST=postgres
DB_PORT=5432
DB_USER=sandboxuser
DB_PASSWORD=sandboxpass123
DB_NAME=sandboxdb
DB_SSLMODE=disable

# JWT configuration
JWT_SECRET=your_secret_jwt_key_change_in_production

# PostgreSQL configuration
POSTGRES_DB=sandboxdb
POSTGRES_USER=sandboxuser
POSTGRES_PASSWORD=sandboxpass123

# pgAdmin configuration
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=admin123

# MinIO configuration
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=user-uploads
MINIO_USE_SSL=false
MINIO_PUBLIC_URL=http://localhost:9000

# Registry configuration (used by deploy.sh)
REGISTRY_URL=registry.example.com
REGISTRY_USER=your_registry_user
REGISTRY_PASSWORD=your_registry_password
IMAGE_NAME=your-image-name
IMAGE_TAG=latest